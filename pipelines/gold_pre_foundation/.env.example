# Variáveis de ambiente exigidas por GoldPreFoundationEnvConfigs.
# Copie para .env (NUNCA versionar .env real) e ajuste os valores conforme o ambiente.

# Projeto GCP onde residem os datasets billing_raw/billing_silver/billing_gold.
GCP_PROJECT=gglobo-billinghomolog-hdg-prd

# Tabela de origem: a Silver COM labels (gcp_billing_silver_label).
# Atenção: NÃO é a gcp_billing_silver sem label.
GCP_SILVER_LABEL_TABLE=gglobo-billinghomolog-hdg-prd.billing_silver.gcp_billing_silver_label

# Tabela de destino da camada Gold Pre-Foundation.
GCP_GOLD_LABEL_PRE_FOUNDATION_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_gold_pre_foundation

# Tabela de mapeamento de serviços de marketplace (usada para identificar
# serviços de suporte no rateio de custo_suporte/credito_suporte).
GCP_MARKETPLACE_SERVICES_TABLE=gglobo-billing-hdg-prd.billing_raw.tb_gcp_marketplace_services

# Limite de divergência (em valor monetário) entre custo gold e custo silver
# acima do qual load_gold_pre_foundation_data() levanta RuntimeError e bloqueia o load.
COST_VALIDATION_LIMIT=15000

# Campos usados para montar parâmetros Jinja de extração de custo unitário
# (separados por vírgula). ATENÇÃO: confirmado por leitura do template SQL
# real que estes parâmetros não têm efeito hoje no SQL renderizado desta
# camada — ver docstring de templates/gold_pre_foundation_query.py. Mantido
# por paridade comportamental com o legado, não por necessidade funcional.
CUSTO_UNITARIO_FIELDS=squad, produto
