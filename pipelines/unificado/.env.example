# Variáveis de ambiente exigidas por UnificadoEnvConfigs.
# Copie para .env (NUNCA versionar .env real) e ajuste os valores conforme o ambiente.

GCP_PROJECT=gglobo-billinghomolog-hdg-prd

# Tabela de destino desta camada (consolidação multicloud GCP/Tsuru/DBaaS).
GCP_GOLD_UNIFICADO_LABEL_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_tsuru_dbaas_unificada_labels

# Limite de divergência (em valor monetário) entre a soma dos provedores e o
# agregado "_gold" de cada um, acima do qual load_gold_unificado_data()
# levanta RuntimeError e bloqueia o load.
COST_VALIDATION_LIMIT=15000
