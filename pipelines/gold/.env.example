# Variáveis de ambiente exigidas por GoldEnvConfigs.
# Copie para .env (NUNCA versionar .env real) e ajuste os valores conforme o ambiente.

GCP_PROJECT=gglobo-billinghomolog-hdg-prd

# Tabela de origem: camada anterior do medalhão (Gold Pre-Foundation).
GCP_GOLD_LABEL_PRE_FOUNDATION_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_gold_pre_foundation

# Tabela "dashboard" da camada Gold Foundation, usada para ratejar o total Foundation.
GCP_GOLD_LABEL_FOUNDATION_DASHBOARD_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_billing_foundation_labels_dashboard

# Tabela de destino desta camada (Gold final).
GCP_GOLD_LABEL_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_billing_projeto_ar_label

# Tabela de mapeamento de serviços de marketplace.
GCP_MARKETPLACE_SERVICES_TABLE=gglobo-billing-hdg-prd.billing_raw.tb_gcp_marketplace_services

# Limite de divergência (em valor monetário) entre custo gold e custo silver
# acima do qual load_gold_data() levanta RuntimeError e bloqueia o load.
COST_VALIDATION_LIMIT=15000

# Campos usados para montar parâmetros Jinja de extração de custo unitário.
# ATENÇÃO: código órfão — generate_custom_columns/generate_null_columns não
# são chamados em load_gold_data nesta camada. Mantido por paridade com o legado.
CUSTO_UNITARIO_FIELDS=squad, produto
