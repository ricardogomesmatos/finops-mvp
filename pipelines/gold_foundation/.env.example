# Variáveis de ambiente exigidas por GoldFoundationEnvConfigs.
# Copie para .env (NUNCA versionar .env real) e ajuste os valores conforme o ambiente.

# Projeto GCP onde residem os datasets billing_raw/billing_gold.
GCP_PROJECT=gglobo-billinghomolog-hdg-prd

# Tabela de origem (camada anterior do medalhão).
GCP_GOLD_LABEL_PRE_FOUNDATION_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_gold_pre_foundation

# Tabela de destino principal desta camada.
GCP_GOLD_LABEL_FOUNDATION_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_billing_foundation_labels

# Tabela de destino "dashboard" desta camada (agregada, usada por Looker Studio).
GCP_GOLD_LABEL_FOUNDATION_DASHBOARD_TABLE=gglobo-billinghomolog-hdg-prd.billing_gold.tb_gcp_billing_foundation_labels_dashboard
