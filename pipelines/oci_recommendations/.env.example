# Variáveis de ambiente exigidas por OciRecommendationsEnvConfigs.
# Copie para .env (NUNCA versionar .env real) e ajuste os valores conforme o ambiente.

# Projeto GCP onde reside o dataset billing_raw.
GCP_PROJECT=gglobo-billinghomolog-hdg-prd

# Tabela de destino do snapshot (formato totalmente qualificado: project.dataset.table).
OCI_RECOMMENDATIONS_TABLE=gglobo-billinghomolog-hdg-prd.billing_raw.tb_oci_optimizer_recommendations_snapshot

# OCID da tenancy OCI usada como escopo da extração (compartment_id_in_subtree=True).
OCI_TENANCY_ID=ocid1.tenancy.oc1..exampleuniqueID

# Nome do secret no Secret Manager (NÃO o valor) com as credenciais da API Key OCI
# (payload JSON esperado: user, fingerprint, tenancy, region, key_content).
OCI_CREDENTIALS_SECRET_ID=oci-optimizer-credentials
